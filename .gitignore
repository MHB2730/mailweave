*.swp

# Signing — never commit certs or thumbprint env files
*.pfx
*.p12
.env
.env.local

# Claude Code local state — never share
.claude/

# Test/verify output that isn't source
_verify_output/
test_*.pdf
test_*.docx

# Stale PyInstaller --onefile residue (MailWeave.spec is the active one)
MailWeave-Setup-*.spec
uninstall.spec

# Build artefact from the legacy custom-installer path (installer_app.py).
